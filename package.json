{
  "name": "@lkeld/fortress-wasm",
  "version": "1.6.0",
  "description": "Virtualised, self-checksumming WebAssembly runtime with steganographic session keys",
  "main": "index.js",
  "bin": {
    "fortress": "./bin/index.js",
    "create-fortress-app": "./packages/create-fortress-app/bin/index.js"
  },
  "exports": {
    "./client": "./packages/sdk/index.js",
    "./sdk": "./packages/sdk/index.js",
    "./next": "./packages/next/index.js",
    "./vite": "./packages/vite/index.js",
    "./sveltekit": "./packages/sveltekit/index.js",
    "./nuxt": "./packages/nuxt/index.js",
    "./remix": "./packages/remix/index.js",
    "./astro": "./packages/astro/index.js",
    "./angular": "./packages/angular/index.js",
    "./solid": "./packages/solid/index.js",
    "./qwik": "./packages/qwik/index.js",
    "./express": "./packages/express/index.js",
    "./fastify": "./packages/fastify/index.js",
    "./hono": "./packages/hono/index.js",
    "./koa": "./packages/koa/index.js",
    "./nestjs": "./packages/nestjs/index.js",
    "./bun": "./packages/bun/index.js",
    "./deno": "./packages/deno/index.js",
    "./html": "./packages/html/index.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "test": "cargo test --manifest-path crates/vm-core/Cargo.toml",
    "test:e2e": "node tests/e2e/runner.js",
    "test:full": "npm run build:compiler && npm run test && npx tsc compiler/tests/compiler.test.ts --esModuleInterop && node --test compiler/tests/compiler.test.js tests/integration.test.js",
    "test:browser": "playwright test",
    "test:stdlib": "node tests/e2e_overhaul/stdlib.test.js",
    "test:transpiler": "node tests/e2e_overhaul/transpiler.test.js",
    "test:cli-integration": "node tests/e2e_overhaul/cli-integration.test.js",
    "test:integrations": "node tests/e2e_overhaul/integrations.test.js",
    "test:dev-server": "node tests/e2e_overhaul/dev-server.test.js",
    "test:annotations": "node tests/e2e_overhaul/annotations.test.js",
    "test:verify": "node tests/e2e_overhaul/verify.test.js",
    "test:opcodes": "node tests/e2e_overhaul/opcodes.test.js",
    "test:sdk": "node tests/e2e_overhaul/sdk.test.js",
    "test:complex": "node tests/e2e_overhaul/complex.test.js",
    "test:auto-inject": "node tests/e2e_overhaul/auto-inject.test.js",
    "test:ci-inject": "node tests/e2e_overhaul/ci-inject.test.js",
    "test:version-compat": "node tests/e2e_overhaul/version-compat.test.js",
    "test:idempotency": "node tests/e2e_overhaul/idempotency.test.js",
    "build:isa:dev": "DEV_MODE=true node scripts/generate_isa.js",
    "build:isa:prod": "node scripts/generate_isa.js",
    "build:compiler": "tsc -p compiler/tsconfig.json",
    "build:server": "tsc -p server/tsconfig.json",
    "build:wasm-node:dev": "wasm-pack build crates/vm-core --target nodejs --out-dir ../../pkg-node -- --features dev && rm -f pkg-node/.gitignore",
    "build:wasm-node:prod": "wasm-pack build crates/vm-core --target nodejs --out-dir ../../pkg-node && rm -f pkg-node/.gitignore",
    "build:wasm-web:dev": "wasm-pack build crates/vm-core --target web --out-dir ../../pkg-web -- --features dev && rm -f pkg-web/.gitignore && node scripts/patch_web.js",
    "build:wasm-web:prod": "wasm-pack build crates/vm-core --target web --out-dir ../../pkg-web && rm -f pkg-web/.gitignore && node scripts/patch_web.js",
    "build:dev": "npm run build:isa:dev && DEV_MODE=true npm run build:compiler && npm run build:server && npm run build:wasm-node:dev && npm run build:wasm-web:dev && node scripts/build.js --only-hashes",
    "build:prod": "npm run build:isa:prod && npm run build:compiler && npm run build:server && npm run build:wasm-node:prod && npm run build:wasm-web:prod && node scripts/build.js --only-hashes",
    "build": "npm run build:prod",
    "dashboard": "node dashboard/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lkeld/fortress-wasm.git"
  },
  "keywords": [
    "wasm",
    "obfuscation",
    "vm",
    "security"
  ],
  "author": "lkeld",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/lkeld/fortress-wasm/issues"
  },
  "homepage": "https://github.com/lkeld/fortress-wasm#readme",
  "dependencies": {
    "@babel/generator": "^7.20.0",
    "@babel/parser": "^7.20.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.20.0",
    "@lkeld/fortress-wasm": "^1.6.0",
    "argon2": "^0.44.0",
    "cross-spawn": "^7.0.3",
    "jimp": "^1.6.1",
    "magicast": "^0.5.3",
    "pngjs": "^7.0.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^25.9.1",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.0.0"
  },
  "optionalDependencies": {
    "isolated-vm": "^6.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "index.js",
    "bin",
    "compiler/dist",
    "server/scrambler.js",
    "server/scrambler.d.ts",
    "server/nonce-store.js",
    "server/nonce-store.d.ts",
    "pkg-node",
    "pkg-web",
    "packages",
    "scripts/generate_isa.js",
    "next.js"
  ]
}
